<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>中国ADAS週報 — {{ week_label }}</title>
  <style>
    /* ── Reset ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ── Base ── */
    body {
      font-family: "Noto Serif JP", Georgia, "Times New Roman", serif;
      background: #f4f0e8;
      color: #1a1a1a;
      line-height: 1.6;
      font-size: 15px;
    }

    a {
      color: #8b1a1a;
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
      color: #8b1a1a;
    }

    /* ── Page wrapper ── */
    .page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 24px 48px;
    }

    /* ════════════════════════════════
       MASTHEAD
    ════════════════════════════════ */
    .masthead {
      background: #1a1a1a;
      color: #f4f0e8;
      padding: 18px 28px 14px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }

    .masthead-left {
      font-size: 0.65rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #a0a0a0;
      line-height: 1.5;
      flex-shrink: 0;
      white-space: nowrap;
    }

    .masthead-center {
      text-align: center;
      flex: 1;
    }

    .masthead-title {
      font-size: clamp(2.5rem, 6vw, 5rem);
      font-weight: 700;
      letter-spacing: 0.05em;
      color: #f4f0e8;
      line-height: 1;
      font-family: "Noto Serif JP", Georgia, "Times New Roman", serif;
    }

    .masthead-right {
      font-size: 0.65rem;
      letter-spacing: 0.06em;
      color: #a0a0a0;
      text-align: right;
      flex-shrink: 0;
      white-space: nowrap;
      line-height: 1.5;
    }

    /* Subtitle bar below masthead */
    .masthead-subtitle {
      background: #f4f0e8;
      text-align: center;
      font-style: italic;
      font-size: 0.8rem;
      letter-spacing: 0.06em;
      color: #1a1a1a;
      padding: 6px 0 8px;
      border-bottom: 3px solid #8b1a1a;
    }

    /* ── Dateline strip ── */
    .dateline {
      text-align: center;
      font-size: 0.68rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #4a4a4a;
      padding: 7px 0;
      border-top: 1px solid #999;
      border-bottom: 1px solid #999;
      margin-bottom: 22px;
    }

    /* ════════════════════════════════
       EXECUTIVE SUMMARY
    ════════════════════════════════ */
    .exec-wrapper {
      position: relative;
      margin-bottom: 28px;
    }

    /* Double border: outer box + inner inset */
    .exec-outer {
      border: 2px solid #1a1a1a;
      padding: 4px;
    }

    .exec-inner {
      border: 1px solid #1a1a1a;
      padding: 18px 24px 16px;
    }

    .exec-heading {
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-variant: small-caps;
      color: #1a1a1a;
      margin-bottom: 12px;
    }

    .exec-list {
      list-style: none;
      padding: 0;
    }

    .exec-list li {
      font-size: 0.9rem;
      line-height: 1.7;
      padding: 8px 0;
      border-bottom: 1px solid #ccc;
      color: #1a1a1a;
    }

    .exec-list li:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    .exec-list li::before {
      content: "◆ ";
      color: #8b1a1a;
      font-size: 0.65rem;
    }

    /* ════════════════════════════════
       SECTION HEADERS
    ════════════════════════════════ */
    .section-header {
      margin: 28px 0 16px;
    }

    .section-hr-top {
      border: none;
      border-top: 2px solid #1a1a1a;
      margin-bottom: 5px;
    }

    .section-title {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-variant: small-caps;
      color: #1a1a1a;
      display: inline-block;
      padding: 3px 0;
    }

    .section-hr-bottom {
      border: none;
      border-top: 1px solid #1a1a1a;
      margin-top: 5px;
    }

    .article-item {
      break-inside: avoid;
      margin-bottom: 1.5rem;
    }

    .article-headline {
      font-size: 1.05rem;
      font-weight: 700;
      line-height: 1.2;
      font-family: "Noto Serif JP", Georgia, "Times New Roman", serif;
      margin-bottom: 5px;
    }

    .article-headline a {
      color: #1a1a1a;
      text-decoration: none;
    }

    .article-headline a:hover {
      color: #8b1a1a;
      text-decoration: none;
    }

    .article-rule {
      border: none;
      border-top: 1px solid #bbb;
      margin: 5px 0 4px;
    }

    .article-byline {
      font-size: 0.7rem;
      font-variant: small-caps;
      letter-spacing: 0.06em;
      color: #666;
      margin-bottom: 6px;
      line-height: 1.4;
    }

    .article-body-text {
      font-size: 0.85rem;
      line-height: 1.6;
      text-align: justify;
      color: #1a1a1a;
      margin-bottom: 7px;
    }

    .article-tags {
      font-size: 0.7rem;
      color: #8b1a1a;
      line-height: 1.6;
    }

    /* ════════════════════════════════
       NEWS GRID
    ════════════════════════════════ */
    .news-grid {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      column-gap: 0;
      row-gap: 0;
    }

    .article-t1 {
      grid-column: 1 / -1;
      border-bottom: 2px solid #1a1a1a;
      padding: 16px 0 20px;
    }
    .article-t2 {
      grid-column: span 3;
      border-right: 1px solid #999;
      border-bottom: 1px solid #ccc;
      padding: 14px 16px 16px 0;
    }
    .article-t2:nth-of-type(even) {
      border-right: none;
      padding-right: 0;
      padding-left: 16px;
    }
    .article-t3 {
      grid-column: span 2;
      border-right: 1px solid #999;
      border-bottom: 1px solid #ccc;
      padding: 12px 14px 14px 0;
    }
    .article-t3:last-of-type { border-right: none; }
    .article-t4 {
      grid-column: span 1;
      border-right: 1px solid #999;
      border-bottom: 1px solid #ccc;
      padding: 10px 10px 12px 0;
    }
    .article-t4:last-child { border-right: none; }

    .headline-t1 {
      font-size: clamp(1.9rem, 3.2vw, 2.4rem);
      font-weight: 700; line-height: 1.12; letter-spacing: 0.01em;
      margin-bottom: 10px;
      font-family: "Noto Serif JP", Georgia, "Times New Roman", serif;
    }
    .headline-t2 {
      font-size: 1.35rem;
      font-weight: 700; line-height: 1.18;
      margin-bottom: 8px;
      font-family: "Noto Serif JP", Georgia, "Times New Roman", serif;
    }
    .headline-t3 {
      font-size: 1.05rem;
      font-weight: 700; line-height: 1.22;
      margin-bottom: 6px;
      font-family: "Noto Serif JP", Georgia, "Times New Roman", serif;
    }
    .headline-t4 {
      font-size: 0.88rem;
      font-weight: 700; line-height: 1.3;
      margin-bottom: 4px;
      font-family: "Noto Serif JP", Georgia, "Times New Roman", serif;
    }
    .headline-t1 a, .headline-t2 a,
    .headline-t3 a, .headline-t4 a { color: #1a1a1a; text-decoration: none; }
    .headline-t1 a:hover, .headline-t2 a:hover,
    .headline-t3 a:hover, .headline-t4 a:hover { color: #8b1a1a; }

    .summary-t1 {
      font-size: 0.95rem; line-height: 1.75; text-align: justify;
      color: #1a1a1a; margin-bottom: 10px; max-width: 72ch;
    }
    .summary-t2 {
      font-size: 0.88rem; line-height: 1.65; text-align: justify;
      color: #1a1a1a; margin-bottom: 8px;
      display: -webkit-box; -webkit-line-clamp: 4;
      -webkit-box-orient: vertical; overflow: hidden;
    }
    .summary-t3 {
      font-size: 0.82rem; line-height: 1.55; color: #1a1a1a; margin-bottom: 6px;
      display: -webkit-box; -webkit-line-clamp: 2;
      -webkit-box-orient: vertical; overflow: hidden;
    }

    .tier-label {
      font-size: 0.62rem; font-weight: 700; letter-spacing: 0.22em;
      text-transform: uppercase; font-variant: small-caps;
      color: #8b1a1a; margin-bottom: 6px; display: block;
    }

    .video-insert {
      grid-column: 1 / -1;
      display: grid; grid-template-columns: 4fr 2fr; gap: 0;
      border-top: 3px double #1a1a1a; border-bottom: 3px double #1a1a1a;
      margin: 12px 0; background: #f4f0e8;
    }
    .video-insert-embed {
      position: relative; padding-top: 37.5%;
      background: #0d0d0d; overflow: hidden;
    }
    .video-insert-embed iframe {
      position: absolute; top: 0; left: 0;
      width: 100%; height: 100%; border: none;
    }
    .video-insert-meta {
      padding: 18px 20px; display: flex;
      flex-direction: column; justify-content: center;
      border-left: 1px solid #333;
    }
    .video-insert-kicker {
      font-size: 0.6rem; font-weight: 700; letter-spacing: 0.2em;
      text-transform: uppercase; color: #8b1a1a; margin-bottom: 10px;
    }
    .video-insert-title {
      font-size: 1.0rem; font-weight: 700; line-height: 1.4;
      color: #1a1a1a; margin-bottom: 12px;
      font-family: "Noto Serif JP", Georgia, "Times New Roman", serif;
    }
    .video-insert-title a { color: #1a1a1a; text-decoration: none; }
    .video-insert-title a:hover { color: #8b1a1a; }
    .video-insert-footer { font-size: 0.72rem; font-variant: small-caps; color: #666; }

    @media (max-width: 768px) {
      .news-grid { grid-template-columns: repeat(4, 1fr); }
      .article-t1 { grid-column: 1 / -1; }
      .article-t2 { grid-column: span 2; }
      .article-t3 { grid-column: span 2; }
      .article-t4 { grid-column: span 1; }
      .video-insert { grid-template-columns: 1fr; }
      .video-insert-embed { padding-top: 56.25%; }
      .video-insert-meta { border-left: none; border-top: 1px solid #333; }
    }
    @media (max-width: 480px) {
      .news-grid { grid-template-columns: 1fr; }
      .article-t1, .article-t2, .article-t3, .article-t4 {
        grid-column: 1 / -1; border-right: none;
      }
    }

    /* ════════════════════════════════
       FOOTER
    ════════════════════════════════ */
    .site-footer {
      border-top: 1px solid #999;
      padding: 18px 0 24px;
      text-align: center;
      font-size: 0.72rem;
      color: #777;
      margin-top: 36px;
      letter-spacing: 0.04em;
    }

    /* ── Masthead responsive ── */
    @media (max-width: 640px) {
      .masthead {
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 10px;
        padding: 14px 16px 12px;
      }

      .masthead-left,
      .masthead-right {
        text-align: center;
        white-space: normal;
      }
    }
  </style>
</head>
<body>

  <!-- ══════════════════════════════
       MASTHEAD
  ══════════════════════════════ -->
  <header>
    <div class="masthead">
      <div class="masthead-left">
        VOL.1&nbsp;NO.{{ week_label | replace("第", "") | replace("週", "") | replace("W", "") | truncate(4, true, "") }}<br>
        中国版
      </div>
      <div class="masthead-center">
        <h1 class="masthead-title">中国ADAS週報</h1>
      </div>
      <div class="masthead-right">
        {{ generated_at }}<br>
        {{ total_articles }} 件の記事
      </div>
    </div>
    <div class="masthead-subtitle">中国自動運転産業インテリジェンス</div>
  </header>

  <div class="page">

    <!-- ── Dateline strip ── -->
    <div class="dateline">
      「{{ week_label }}」&nbsp;&nbsp;·&nbsp;&nbsp;本紙特別版&nbsp;&nbsp;·&nbsp;&nbsp;Powered by Momenta Intelligence
    </div>

    <!-- ══════════════════════════════
         EXECUTIVE SUMMARY
    ══════════════════════════════ -->
    <section aria-labelledby="exec-heading">
      <div class="exec-wrapper">
        <div class="exec-outer">
          <div class="exec-inner">
            <p class="exec-heading" id="exec-heading">■ 今週の三大トピック</p>
            <ul class="exec-list">
              {% for point in executive_summary %}
              <li>{{ point }}</li>
              {% endfor %}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════
         ARTICLES + VIDEO GRID
    ══════════════════════════════ -->
    <section aria-labelledby="articles-heading">
      <div class="section-header">
        <hr class="section-hr-top">
        <span class="section-title" id="articles-heading">▌ ADAS動向</span>
        <hr class="section-hr-bottom">
      </div>

      <div class="news-grid">
      {% set video_idx = namespace(value=0) %}
      {% for article in articles %}

        {% if article.credibility_score >= 8 %}
          {% set cred_label = "公式発表" %}
        {% elif article.credibility_score >= 6 %}
          {% set cred_label = "報道" %}
        {% elif article.credibility_score >= 4 %}
          {% set cred_label = "評価・レポート" %}
        {% else %}
          {% set cred_label = "情報源未確認" %}
        {% endif %}

        <article class="article-t{{ article.tier }}">
          {% if article.tier == 1 %}
          <span class="tier-label">◈ 本週の主要記事</span>
          {% endif %}
          <h2 class="headline-t{{ article.tier }}">
            <a href="{{ article.url }}" target="_blank" rel="noopener noreferrer">
              {{ article.title_ja if article.title_ja else article.title }}
            </a>
          </h2>
          <hr class="article-rule">
          <p class="article-byline">
            {{ article.source }}&nbsp;·&nbsp;{{ cred_label }}
            {% if article.published_at %}&nbsp;·&nbsp;{{ article.published_at[:10] }}{% endif %}
          </p>
          {% if article.tier <= 3 and article.summary_ja %}
          <p class="summary-t{{ article.tier }}">{{ article.summary_ja }}</p>
          {% endif %}
          {% if article.tier <= 2 and article.tags %}
          <p class="article-tags">
            {% for tag in article.tags %}▶ {{ tag }}{% if not loop.last %}&nbsp;&nbsp;{% endif %}{% endfor %}
          </p>
          {% endif %}
        </article>

        {% if loop.index % 4 == 0 and video_idx.value < videos|length %}
        <div class="video-insert">
          <div class="video-insert-embed">
            <iframe src="{{ videos[video_idx.value].embed_url }}"
                    scrolling="no" frameborder="0"
                    allowfullscreen="true" loading="lazy"></iframe>
          </div>
          <div class="video-insert-meta">
            <span class="video-insert-kicker">▌ 動画通信員リポート</span>
            <p class="video-insert-title">
              <a href="{{ videos[video_idx.value].url }}" target="_blank" rel="noopener noreferrer">
                {{ videos[video_idx.value].title_ja or videos[video_idx.value].title }}
              </a>
            </p>
            <div class="video-insert-footer">
              {{ videos[video_idx.value].author }}&nbsp;·&nbsp;スコア {{ "%.1f"|format(videos[video_idx.value].relevance_score) }}
            </div>
          </div>
        </div>
        {% set video_idx.value = video_idx.value + 1 %}
        {% endif %}

      {% endfor %}

      {% for v in videos[video_idx.value:] %}
      <div class="video-insert">
        <div class="video-insert-embed">
          <iframe src="{{ v.embed_url }}"
                  scrolling="no" frameborder="0"
                  allowfullscreen="true" loading="lazy"></iframe>
        </div>
        <div class="video-insert-meta">
          <span class="video-insert-kicker">▌ 動画通信員リポート</span>
          <p class="video-insert-title">
            <a href="{{ v.url }}" target="_blank" rel="noopener noreferrer">
              {{ v.title_ja or v.title }}
            </a>
          </p>
          <div class="video-insert-footer">
            {{ v.author }}&nbsp;·&nbsp;スコア {{ "%.1f"|format(v.relevance_score) }}
          </div>
        </div>
      </div>
      {% endfor %}

      </div><!-- /.news-grid -->
    </section>

    <!-- ── Footer ── -->
    <footer class="site-footer">
      &copy; 2026 Momenta Intelligence &mdash; 中国ADAS週報 &mdash; 無断転載禁止
    </footer>

  </div><!-- /.page -->

</body>
</html>
